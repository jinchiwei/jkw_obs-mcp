# Example .env for jkw-obs-mcp.
#
# Real values go at ~/.config/jkw-obs-mcp/.env (NOT in this repo).
# python-dotenv loads them into the MCP server's process at startup.
# Your shell is never touched.
#
# Pick ONE auth path:
#
# Option A: UCSF Versa via Bedrock (free for UCSF research)
#ANTHROPIC_BEDROCK_BASE_URL=https://unified-api.ucsf.edu/general/awsai
#AWS_REGION=us-west-2
#AWS_ACCESS_KEY_ID=...
#AWS_SECRET_ACCESS_KEY=...
#
# Option B: Direct Anthropic API
#ANTHROPIC_API_KEY=sk-ant-...
